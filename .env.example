# JidoClaw Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Provider Keys ─────────────────────────────────────────
# Only set the key for your chosen provider. Run `jido --setup` to configure.

# Ollama (local — no key needed, or use "ollama" as placeholder)
# OLLAMA_API_KEY=ollama

# Ollama Cloud
# OLLAMA_API_KEY=your-ollama-cloud-key

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GOOGLE_API_KEY=AIza...

# Groq
# GROQ_API_KEY=gsk_...

# xAI (Grok)
# XAI_API_KEY=xai-...

# OpenRouter (200+ models via unified API)
# OPENROUTER_API_KEY=sk-or-...

# ─── Platform ──────────────────────────────────────────────────

# Mode: cli (REPL only), gateway (HTTP/WS only), both (default)
# JIDOCLAW_MODE=both

# Gateway port
# JIDOCLAW_PORT=4000

# ─── Channel Adapters ─────────────────────────────────────────

# Discord
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_GUILD_ID=your-guild-id

# Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Canopy Workspace (optional) ──────────────────────────────

# CANOPY_WORKSPACE_URL=https://your-org.canopy.dev
# CANOPY_API_KEY=your-canopy-key
